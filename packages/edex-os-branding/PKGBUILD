# Maintainer: eDEX-OS Project <https://github.com/eDEX-OS>
pkgname=edex-os-branding
pkgver=1.0.0
pkgrel=1
pkgdesc="eDEX-OS Plymouth theme, GRUB theme, and wallpapers"
arch=('any')
url="https://github.com/eDEX-OS/eDEX-OS"
license=('GPL3')
depends=('plymouth' 'grub')
source=("git+https://github.com/eDEX-OS/eDEX-OS.git")
sha256sums=('SKIP')

package() {
    cd "${srcdir}/eDEX-OS"

    install -dm755 "${pkgdir}/usr/share/plymouth/themes/edex-os"
    cp -r branding/plymouth/edex-os/* "${pkgdir}/usr/share/plymouth/themes/edex-os/"

    install -dm755 "${pkgdir}/usr/share/grub/themes/edex-os"
    cp -r branding/grub/edex-os/* "${pkgdir}/usr/share/grub/themes/edex-os/"

    install -dm755 "${pkgdir}/usr/share/edex-os/wallpapers"
    cp branding/wallpapers/* "${pkgdir}/usr/share/edex-os/wallpapers/" 2>/dev/null || true
}

post_install() {
    plymouth-set-default-theme edex-os -R || true

    if [[ -f /etc/default/grub ]]; then
        sed -i 's|^#\?GRUB_THEME=.*|GRUB_THEME=/usr/share/grub/themes/edex-os/theme.txt|' /etc/default/grub
        grub-mkconfig -o /boot/grub/grub.cfg 2>/dev/null || true
    fi
}

post_upgrade() {
    post_install
}
